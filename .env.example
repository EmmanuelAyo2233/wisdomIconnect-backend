# Environment Variables for Backend - UPDATED

# ============================================
# DATABASE CONFIGURATION
# ============================================
DB_HOST=your-database-host
DB_PORT=3306
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_NAME=wisdom_connect_prod
DB_NAME_DEV=wisdom_connect_dev
DB_NAME_TEST=wisdom_connect_test

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=5000
NODE_ENV=production

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
SECRET_KEY=your-super-secret-key-here
JWT_SECRET=your-jwt-secret-key

# ============================================
# FRONTEND & CORS CONFIGURATION
# ============================================
FRONTEND_URL=https://wisdom-iconnect.vercel.app

# ✅ FIXED: Backend URL for Image Uploads
# This is CRITICAL for chat images to load correctly on production
# Set this to your API domain (must match where backend is deployed)
BACKEND_URL=https://api.your-domain.com

# Example values:
# Production: BACKEND_URL=https://wisdom-connect-api.vercel.app
# Development: BACKEND_URL=http://localhost:5000
# Staging: BACKEND_URL=https://staging-api.your-domain.com

# ============================================
# CLOUDINARY (Image Storage)
# ============================================
CLOUDINARY_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_SECRET_KEY=your-cloudinary-secret-key
CLOUDINARY_FOLDER_NAME=wisdom-connect

# ============================================
# EMAIL CONFIGURATION (Brevo/Sendinblue)
# ============================================
BREVO_API_KEY=your-brevo-api-key
SMTP_SEVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_EMAIL=your-smtp-email
SMTP_PASSWORD=your-smtp-password

# ============================================
# PAYMENT CONFIGURATION (Paystack)
# ============================================
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key
# NOTE: Never commit real API keys to git!

# ============================================
# TESTING
# ============================================
TEST_DATABASE=wisdom_connect_test
